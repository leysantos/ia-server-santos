# Copie para .env.local quando a equipe SEMINF acessar pela rede interna (LAN).
# Reinicie o frontend após alterar.
#
# Na LAN o browser usa proxy same-origin (/api-backend → :8000 no servidor).
# Este valor só afeta acesso em localhost; na rede pode ficar localhost:8000.

NEXT_PUBLIC_API_URL=http://localhost:8000
