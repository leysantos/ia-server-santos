# IA Server Santos — variáveis de ambiente (exemplo)
# Copie para backend/.env e ajuste para produção.

# PostgreSQL (prefer DATABASE_URL em produção)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ia_server_santos
DB_USER=ia_user
DB_PASSWORD=change-me-in-production
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
DB_ENABLED=true

# CORS (frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Autenticação JWT — troque ANTES de Quick Tunnel / Cloudflare prolongado
AUTH_ENABLED=true
JWT_SECRET=change-me-jwt-secret-in-production-min-32-chars
JWT_EXPIRE_MINUTES=480
# Senhas iniciais (seed na primeira subida do banco) — altere em produção
AUTH_SEED_ADMIN_PASSWORD=Admin@2026!
AUTH_SEED_DEV_PASSWORD=Dev@2026!
# AUTH_HARDENING_STRICT=true  # falha o startup se JWT/senhas ainda forem padrão

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3.6:latest
OLLAMA_LLM_FALLBACK_MODEL=gemma4:latest
OLLAMA_CHAT_MODEL=phi3:mini
OLLAMA_BUDGET_MODEL=qwen2.5-coder:latest

# Model Router (default: true)
USE_MODEL_ROUTER=true
USE_MODEL_EVALUATION=false
USE_BUDGET_SMART_ROUTING=true
USE_ENGINEERING_SMART_ROUTING=true
# Timeout estendido para modelos pesados (qwen3.6, gemma4, deepseek-r1, etc.) — segundos
OLLAMA_HEAVY_MODEL_TIMEOUT=300

# Feature flags experimentais (código em experimental/)
USE_EVOLUTION_LOOP=false
USE_TUNED_PROMPTS=false

# Orçamento SEMINF — PDF Planilha/MCQ (LibreOffice headless)
# WSL: rode `make libreoffice` ou aponte para soffice.exe do Windows
# LIBREOFFICE_PATH=/mnt/c/Program Files/LibreOffice/program/soffice.exe
